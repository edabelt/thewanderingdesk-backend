{{> welcome-menu active="login"}}

<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-half">

        {{> error}}

        <div class="box">
          <h1 class="title is-3 has-text-centered">Log In</h1>
          <p class="subtitle is-6 has-text-centered">
            Access your Wondering Deskt account to manage your lists of workspaces.
          </p>

          <form action="/authenticate" method="POST">
            <div class="field">
              <label class="label">Email</label>
              <div class="control">
                <input class="input" type="text" placeholder="Enter your email" name="email">
              </div>
            </div>

            <div class="field">
              <label class="label">Password</label>
              <div class="control">
                <input class="input" type="password" placeholder="Enter your password" name="password">
              </div>
            </div>

            <div class="field">
              <div class="control">
                <button class="button is-link is-fullwidth">Log In</button>
              </div>
            </div>
          </form>

        </div>
      </div>
    </div>
  </div>
</section>