{{> menu active="dashboard"}}

<section class="section">
  <div class="container">
    <h1 class="title is-3">Workspace Dashboard</h1>
    <p class="subtitle is-6">
      Manage your categories and workspaces.
    </p>

    {{> error}}

    <div class="columns is-variable is-6">
      <div class="column is-two-thirds">
        <div class="box">
          <h2 class="title is-5">Your Categories</h2>
          {{> list-categories}}
        </div>
      </div>

      <div class="column">
        <div class="box">
          <h2 class="title is-5">Add New Category</h2>
          {{> add-category}}
        </div>
      </div>
    </div>
  </div>
</section>